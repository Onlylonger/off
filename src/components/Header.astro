---
import Menu from "./Menu.astro";
import MobileMenu from "./MobileMenu.astro";

const { class: className, ...reset} =  Astro.props

---

<header class:list={[className, 'bg-gray-200/20']} {...reset}>
  <div class="container flex justify-between items-center mx-auto h-14">
    <MobileMenu class="md:hidden relative" />

	<Menu class="hidden md:flex items-center h-full gap-5"/>
    <div class="h-full flex items-center">
      <span class="inline-block size-4 bg-black rounded-full cursor-pointer hover:scale-110"></span>
    </div>
  </div>
</header>
