---
import Link from "./Link.astro";
const { class: className, ...reset} =  Astro.props

const today = new Date();
---

<footer class:list={[className, 'container px-4 border-t border-dashed border-black flex justify-between mx-auto pt-6 text-base']} {...reset}>
	<div>
		© {today.getFullYear()} <Link href="/">Barry</Link>. All rights reserved.
	</div>
	
	<div>
		<span>😊</span>
		<span>😋</span>
		<span>🤔</span>
	</div>
</footer>

